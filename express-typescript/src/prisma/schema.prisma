// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "mysql"
}



// Lưu ý: db push sẽ tạo bảng mới nếu bảng chưa tồn tại, nhưng sẽ không xóa cột hoặc bảng đã tồn tại nếu chúng không còn trong schema. 
// Nếu bạn muốn đồng bộ hoàn toàn với schema, bạn có thể sử dụng db reset, nhưng hãy cẩn thận vì nó sẽ xóa tất cả dữ liệu hiện có trong cơ sở dữ liệu của bạn.
// sử dụng câu lệnh pnpm: lnpx prisma db push --preview-feature để đồng bộ schema với cơ sở dữ liệu mà không mất dữ liệu hiện có.


// có thể sử dụng db pull để cập nhật schema từ cơ sở dữ liệu nếu có thay đổi trực tiếp trên cơ sở dữ liệu, 
//nhưng hãy cẩn thận vì nó có thể gây mất dữ liệu nếu có sự khác biệt lớn giữa schema và cơ sở dữ liệu.