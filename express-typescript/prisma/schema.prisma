// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "mysql"
}

model User {
  id        Int      @id @default(autoincrement())
  name      String
  email     String?   @unique
  status    Boolean   @default(false)
  bio       String?   @db.Text
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@map("users") // Đặt tên bảng trong cơ sở dữ liệu là "users"
}

model Product {
  id          String      @id @default(uuid())
  name        String
  price       Int
  description String?
  status      Boolean   @default(true)
  createdAt   DateTime  @default(now()) @db.Timestamp()
  updatedAt   DateTime  @updatedAt @db.Timestamp()

  @@map("products") // Đặt tên bảng trong cơ sở dữ liệu là "products"
  @@index([price, description]) // Tạo index trên trường price và description để tăng tốc độ truy vấn
  @@index([name]) // Tạo index trên trường name để tăng tốc độ truy vấn
}
