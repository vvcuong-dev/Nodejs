// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "mysql"
}

model User {
  id        Int      @id @default(autoincrement())
  name      String
  email     String?   @unique
  status    Boolean   @default(false)
  bio       String?   @db.Text
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  userInfo  UserInfo?
  posts    Post[]
  orders   Order[] 
  userOrders UserOrder[]

  @@map("users") 
}

model Post {
  id        Int      @id @default(autoincrement())
  title     String
  content   String?   @db.Text
  user     User?     @relation(fields: [userId], references: [id], onDelete: Cascade) // onDelete: cascade là để khi xóa user thì bài viết cũng sẽ bị xóa theo
  userId   Int?
  createdAt DateTime?  @default(now()) @db.Timestamp() @map("created_at")
  updatedAt DateTime?  @updatedAt      @db.Timestamp() @map("updated_at")

  @@map("posts") 
}



model UserInfo {
  id        Int      @id @default(autoincrement())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade) // onDelete: cascade là để khi xóa user thì thông tin user cũng sẽ bị xóa theo
  userId    Int      @unique 
  address   String?
  province  String?
  createdAt DateTime?  @default(now()) @db.Timestamp() @map("created_at")
  updatedAt DateTime?  @updatedAt      @db.Timestamp() @map("updated_at")

  @@map("user_infos")
}

model Product {
  id          String      @id @default(uuid())
  name        String
  price       Int
  description String?
  status      Boolean   @default(true)
  createdAt   DateTime?  @default(now()) @db.Timestamp() @map("created_at")
  updatedAt   DateTime?  @updatedAt @db.Timestamp() @map("updated_at")

  @@map("products") 
  @@index([price, description]) 
  @@index([name])
}


enum OrderStatus {
  PENDING
  SHIPPED
  COMPLETED
  CANCELED
}
model Order {
  id        String      @id @default(uuid())
  total     Int
  status    OrderStatus @default(PENDING)
  createdAt DateTime?  @default(now()) @db.Timestamp() @map("created_at")
  updatedAt DateTime?  @updatedAt @db.Timestamp() @map("updated_at")
  users     User[]
  userOrders UserOrder[]

  @@map("orders") 
}

model UserOrder {
  id Int @id @default(autoincrement())
  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade) 
  orderId String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId Int


  @@map("user_orders") 
}


model Category {
  id          Int         @id @default(autoincrement())
  name        String
  parentId    Int?        @map("parent_id")
  parent      Category?   @relation("CategoryToCategory", fields: [parentId], references: [id], onDelete: Cascade)  
  // fields: [parentId] — dùng cột parentId làm khóa ngoại, 
  // references: [id] — trỏ đến id của chính bảng categories
  categories  Category[]  @relation("CategoryToCategory")
  createdAt   DateTime?   @default(now()) @db.Timestamp() @map("created_at")
  updatedAt   DateTime?   @updatedAt @db.Timestamp() @map("updated_at")

  @@map("categories") 
}